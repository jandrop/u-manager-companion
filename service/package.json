{
  "name": "u-manager-companion-service",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone same-origin GraphQL service for the u-manager-companion Unraid plugin.",
  "type": "commonjs",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node build/bundle.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bundle": "npm run build",
    "sea": "bash scripts/build-sea.sh",
    "sea:size-check": "node scripts/check-size-budget.mjs"
  },
  "dependencies": {
    "@apollo/server": "^5.0.0",
    "dockerode": "^4.0.12",
    "execa": "^9.6.1",
    "graphql": "^16.9.0",
    "graphql-subscriptions": "^2.0.0",
    "graphql-ws": "^5.16.2",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.47",
    "@types/node": "^22.9.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.24.0",
    "postject": "^1.0.0-alpha.6",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
